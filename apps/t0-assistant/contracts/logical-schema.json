{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockpilot.local/contracts/t0-logic-v1.schema.json",
  "title": "StockPilot T+0 cross-process logical schema",
  "description": "Stable process-boundary data contract. This is not a SQLite schema and must not expose provider, transport, or storage fields.",
  "type": "object",
  "$defs": {
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "code", "market", "name", "security_type"],
      "properties": {
        "symbol": {"type": "string", "pattern": "^(sh|sz)\\.[0-9]{6}$"},
        "code": {"type": "string", "pattern": "^[0-9]{6}$"},
        "market": {"enum": ["sh", "sz"]},
        "name": {"type": "string", "minLength": 1},
        "security_type": {"enum": ["a_share", "etf"]}
      }
    },
    "bar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "open", "high", "low", "close", "volume", "amount", "closed"],
      "properties": {
        "timestamp": {"type": "string", "minLength": 10},
        "open": {"type": "number", "minimum": 0},
        "high": {"type": "number", "minimum": 0},
        "low": {"type": "number", "minimum": 0},
        "close": {"type": "number", "minimum": 0},
        "volume": {"type": "number", "minimum": 0},
        "amount": {"type": "number", "minimum": 0},
        "closed": {"type": "boolean"}
      }
    },
    "quote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "latest_price", "change_percent", "open", "high", "low", "previous_close", "volume", "amount", "volume_ratio", "order_imbalance", "turnover_rate"],
      "properties": {
        "timestamp": {"type": "string", "minLength": 19},
        "latest_price": {"type": "number", "minimum": 0},
        "change_percent": {"type": "number"},
        "open": {"type": "number", "minimum": 0},
        "high": {"type": "number", "minimum": 0},
        "low": {"type": "number", "minimum": 0},
        "previous_close": {"type": "number", "minimum": 0},
        "volume": {"type": "number", "minimum": 0},
        "amount": {"type": "number", "minimum": 0},
        "volume_ratio": {"type": ["number", "null"]},
        "order_imbalance": {"type": ["number", "null"]},
        "turnover_rate": {"type": ["number", "null"]}
      }
    },
    "indicator_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "value"],
      "properties": {
        "timestamp": {"type": "string", "minLength": 10},
        "value": {"type": ["number", "null"]}
      }
    },
    "macd": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fast_period", "slow_period", "signal_period", "dif", "dea", "histogram"],
      "properties": {
        "fast_period": {"const": 12},
        "slow_period": {"const": 26},
        "signal_period": {"const": 9},
        "dif": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
        "dea": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
        "histogram": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}}
      }
    },
    "indicators": {
      "type": "object",
      "additionalProperties": false,
      "required": ["five_minute", "one_minute"],
      "properties": {
        "five_minute": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ma", "boll", "volume", "macd"],
          "properties": {
            "ma": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ma5", "ma10", "ma20", "ma30", "ma60"],
              "properties": {
                "ma5": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "ma10": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "ma20": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "ma30": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "ma60": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}}
              }
            },
            "boll": {
              "type": "object",
              "additionalProperties": false,
              "required": ["period", "stddev", "upper", "middle", "lower"],
              "properties": {
                "period": {"const": 20},
                "stddev": {"const": 2.0},
                "upper": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "middle": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "lower": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}}
              }
            },
            "volume": {
              "type": "object",
              "additionalProperties": false,
              "required": ["values", "ma5", "ma10"],
              "properties": {
                "values": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "ma5": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
                "ma10": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}}
              }
            },
            "macd": {"$ref": "#/$defs/macd"}
          }
        },
        "one_minute": {
          "type": "object",
          "additionalProperties": false,
          "required": ["vwap", "volume", "macd"],
          "properties": {
            "vwap": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}},
            "volume": {
              "type": "object",
              "additionalProperties": false,
              "required": ["values"],
              "properties": {"values": {"type": "array", "items": {"$ref": "#/$defs/indicator_point"}}}
            },
            "macd": {"$ref": "#/$defs/macd"}
          }
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warning_code", "severity", "message", "affected_capability", "affected_field", "details"],
      "properties": {
        "warning_code": {"type": "string", "minLength": 1},
        "severity": {"enum": ["info", "warning"]},
        "message": {"type": "string", "minLength": 1},
        "affected_capability": {"enum": ["replay", "intraday_chart", "five_minute_chart", "chan_analysis"]},
        "affected_field": {"type": "string"},
        "details": {"type": "object"}
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "session_type", "symbol", "trade_date", "state", "revision"],
      "properties": {
        "session_id": {"type": "string", "minLength": 1},
        "session_type": {"enum": ["live", "replay"]},
        "symbol": {"type": "string", "pattern": "^(sh|sz)\\.[0-9]{6}$"},
        "trade_date": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "state": {"enum": ["created", "loading", "ready", "playing", "paused", "failed", "retired"]},
        "revision": {"type": "integer", "minimum": 0}
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bars_1m", "bars_5m", "daily_bars", "quote"],
      "properties": {
        "bars_1m": {"type": "array", "items": {"$ref": "#/$defs/bar"}},
        "bars_5m": {"type": "array", "items": {"$ref": "#/$defs/bar"}},
        "daily_bars": {"type": "array", "items": {"$ref": "#/$defs/bar"}},
        "quote": {"oneOf": [{"$ref": "#/$defs/quote"}, {"type": "null"}]}
      }
    },
    "chan_analysis": {
      "type": "object",
      "description": "Project-owned chantheory AnalysisResult.to_dict() payload. Raw czsc engine objects are forbidden.",
      "additionalProperties": false,
      "required": ["symbol", "timeframe", "source", "engine", "engine_version", "parameters", "fractals", "strokes", "segments", "pivot_zones", "divergences", "structure_alerts", "signal_series", "signal_events", "signal_snapshots", "candidate_point_events", "candidate_buy_points", "candidate_sell_points", "plot_primitives", "summary", "warnings", "meta"],
      "properties": {
        "symbol": {"type": "string", "minLength": 1},
        "timeframe": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "engine": {"const": "czsc"},
        "engine_version": {"type": "string", "minLength": 1},
        "parameters": {"type": "object"},
        "fractals": {"type": "array", "items": {"type": "object"}},
        "strokes": {"type": "array", "items": {"type": "object"}},
        "segments": {"type": "array", "items": {"type": "object"}},
        "pivot_zones": {"type": "array", "items": {"type": "object"}},
        "divergences": {"type": "array", "items": {"type": "object"}},
        "structure_alerts": {"type": "array", "items": {"type": "object"}},
        "signal_series": {"type": "array", "items": {"type": "object"}},
        "signal_events": {"type": "array", "items": {"type": "object"}},
        "signal_snapshots": {"type": "array", "items": {"type": "object"}},
        "candidate_point_events": {"type": "array", "items": {"type": "object"}},
        "candidate_buy_points": {"type": "array", "items": {"type": "object"}},
        "candidate_sell_points": {"type": "array", "items": {"type": "object"}},
        "plot_primitives": {"type": "array", "items": {"type": "object"}},
        "summary": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "object"}},
        "meta": {"type": "object"}
      }
    },
    "workbench_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timezone", "session", "market", "indicators", "chan_analysis", "warnings"],
      "properties": {
        "timezone": {"const": "Asia/Shanghai"},
        "session": {"$ref": "#/$defs/session"},
        "replay": {"type": ["object", "null"]},
        "market": {"$ref": "#/$defs/market"},
        "indicators": {"$ref": "#/$defs/indicators"},
        "chan_analysis": {"$ref": "#/$defs/chan_analysis"},
        "warnings": {"type": "array", "items": {"$ref": "#/$defs/warning"}}
      }
    }
  }
}
